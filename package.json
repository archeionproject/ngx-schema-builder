{
  "name": "ngx-schema-builder-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "npm run build:styles && ng build ngx-schema-builder",
    "build:styles": "tailwindcss -i projects/ngx-schema-builder/styles/jsonjoy.source.css -o projects/ngx-schema-builder/assets/styles/jsonjoy.css --minify",
    "build:demo": "ng build demo",
    "watch": "ng build ngx-schema-builder --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "release-it --config .release-it.ngx-schema-builder.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "projects/ngx-schema-builder/**/*.{ts,html}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^2.5.5",
    "tslib": "^2.3.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@release-it/bumper": "^6.0.1",
    "@release-it/conventional-changelog": "^8.0.2",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.10.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "ng-packagr": "^21.2.3",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "release-it": "^17.11.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.0.18"
  }
}
