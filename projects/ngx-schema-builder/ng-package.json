{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/ngx-schema-builder",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    {
      "glob": "**/*",
      "input": "assets/",
      "output": "assets/"
    }
  ],
  "allowedNonPeerDependencies": [
    "@codemirror/commands",
    "@codemirror/lang-json",
    "@codemirror/language",
    "@codemirror/lint",
    "@codemirror/state",
    "@codemirror/view",
    "@lezer/highlight",
    "ajv",
    "ajv-formats",
    "clsx",
    "codemirror",
    "tailwind-merge",
    "zod"
  ]
}
